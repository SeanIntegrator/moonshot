PORT=3000
# Must include a username before @ (Railway/Neon URLs already do). A bare host or empty user causes:
#   PostgreSQL error 28000 — "no PostgreSQL user name specified in startup packet"
DATABASE_URL=postgres://user:pass@localhost:5432/moonshot
JWT_SECRET=change-me-in-production
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# Comma-separated emails allowed to POST/PATCH/DELETE menu items (Phase 1)
MENU_ADMIN_EMAILS=owner@example.com
